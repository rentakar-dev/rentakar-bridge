# ════════════════════════════════════════
# RentaKar Bridge Server — Environment
# Rename file ini menjadi .env
# ════════════════════════════════════════

# MQTT (HiveMQ Cloud)
MQTT_BROKER=xxxxxxxx.s2.eu.hivemq.cloud
MQTT_USER=rentakar_bridge
MQTT_PASS=password_broker_anda
MQTT_PORT=8883

# Firebase
FIREBASE_DB_URL=https://rentakar-gps-default-rtdb.firebaseio.com
FIREBASE_KEY_PATH=./firebase-service-account.json
# Atau gunakan JSON langsung (untuk Railway/Render):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Server
PORT=3000
NODE_ENV=production
